# intuit-engram env file template.
#
# Copy this to "intuit-engram.env" (no .example suffix) next to the binary,
# or anywhere you point INTUIT_ENGRAM_ENV_FILE at, and fill in the values.
#
# Rules:
#   - format: KEY=VALUE, one per line
#   - lines starting with '#' are comments
#   - blank lines are ignored
#   - shell env vars take precedence over this file (file is "last resort")
#   - quotes around values are optional and stripped if matching

# ─── Cloud database (PostgreSQL) ─────────────────────────────────────────
# DSN of the cloud-side Postgres. Required for `cloud serve` and `cloud sync`.
INTUIT_ENGRAM_DATABASE_URL=postgres://engram:engram_dev_pass@devserver01.intuit.ar:5433/engram_cloud?sslmode=disable

# ─── IntuitHub integration ───────────────────────────────────────────────
# Base URL of the IntuitHub-API. Trailing slash optional.
INTUIT_ENGRAM_INTUITHUB_BASE_URL=https://devserver01.intuit.ar/intuit-hub-api/

# Admin X-API-Key for the engram-cloud-sync collaborator. This identity must
# belong to a team with HasFullVisibility=true so the sync sees every team
# and collaborator.
INTUIT_ENGRAM_INTUITHUB_ADMIN_KEY=replace-me-with-the-real-key

# ─── Cloud bind / runtime (only needed when running `cloud serve`) ───────
# INTUIT_ENGRAM_CLOUD_HOST=127.0.0.1
# ENGRAM_PORT=8080
# INTUIT_ENGRAM_JWT_SECRET=replace-with-32+-byte-random-string
# INTUIT_ENGRAM_CLOUD_ADMIN=admin-bearer-token

# ─── Local-side (agent / dev workstation) ────────────────────────────────
# Only relevant if this same env file is used for the local agent CLI.
# INTUIT_ENGRAM_DATA_DIR=
# INTUIT_ENGRAM_CLOUD_SERVER=
# INTUIT_ENGRAM_CLOUD_TOKEN=
